// Minimal config.h for libexif — generated by CMake

#ifndef _LIBEXIF_CONFIG_H
#define _LIBEXIF_CONFIG_H

#define VERSION "@LIBEXIF_VERSION@"

// Disable gettext/NLS — we don't need translated tag descriptions
#undef ENABLE_NLS
#define GETTEXT_PACKAGE "libexif"
#define LOCALEDIR ""

// MSVC does not provide ssize_t (POSIX type)
#ifdef _MSC_VER
#include <BaseTsd.h>
typedef SSIZE_T ssize_t;
#endif

@endianness_def@

#endif /* _LIBEXIF_CONFIG_H */
